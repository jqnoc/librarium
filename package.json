{
  "name": "librarium",
  "version": "2.1.0-beta",
  "description": "A local application for tracking personal book reading statistics",
  "author": "Joaquín Ossorio-Castillo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:backend": "node scripts/build_backend.js",
    "build": "npm run build:backend && electron-builder --win"
  },
  "private": true,
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.librarium.app",
    "productName": "Librarium",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "scripts/python_command.js",
      "static/**/*"
    ],
    "extraResources": [
      {
        "from": "build/backend/librarium-backend.exe",
        "to": "backend/librarium-backend.exe"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "static/logo.png",
      "signAndEditExecutable": false
    }
  }
}
